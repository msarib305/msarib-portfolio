# Keystatic — local mode (no env vars required)
# Uncomment these when upgrading to GitHub mode for Vercel production editing:
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=          # random 32-char string for session signing
# KEYSTATIC_URL=             # https://msarib.dev

# ---------------------------------------------------------------
# Cloudinary — Phase 14
# ---------------------------------------------------------------

# Cloud name from cloudinary.com/console -> Settings -> Account
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=ddgwzcrim

# ---------------------------------------------------------------
# Contact form — Phase 12
# ---------------------------------------------------------------

# Resend API key — get from resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Sender address — must be on a domain verified in Resend dashboard
# Verify msarib.dev: add DKIM + SPF DNS records in Namecheap.
RESEND_FROM_EMAIL=hello@msarib.dev

# Destination inbox for contact form submissions
RESEND_TO_EMAIL=msarib.contact@gmail.com

# Cloudflare Turnstile — get keys at cloudflare.com/turnstile
# Create a site for msarib.dev, choose "Managed" challenge type.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x_your_site_key_here
TURNSTILE_SECRET_KEY=0x_your_secret_key_here

# ---------------------------------------------------------------
# SEO verification — Phase 13
# ---------------------------------------------------------------

# Google Search Console: Add property at search.google.com/search-console
# URL prefix method -> https://msarib.dev -> HTML tag -> copy content="..." value
NEXT_GOOGLE_SITE_VERIFICATION=

# ---------------------------------------------------------------
# Playwright test suite — Phase 15
# ---------------------------------------------------------------

# When true, sendContactEmail() returns immediately without calling Resend.
# playwright.config.ts sets this automatically via webServer.env.
# Never set to true in production.
RESEND_MOCK=false

# When true, src/lib/rate-limit.ts uses an 8-second window instead of 5 minutes.
# playwright.config.ts sets this automatically via webServer.env.
# Never set to true in production.
RATE_LIMIT_TEST_MODE=false
