# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright-mcp scratch + lighthouse outputs
.playwright-mcp/
/lighthouse-reports/
/lighthouse-report/

# Playwright test artefacts (reports and traces; NOT snapshots — baselines are committed)
/test-results/
/playwright-report/

# Windows / WSL artifacts
*:Zone.Identifier
C:\\Users\\*

# Local-only screenshots produced during verification runs
/local-*.png
/baseline-*.png
/hero-phase*.png
/phase*.png
/design-system.png

# Career documentation (private, kept out of repo)
/docs/PROFESSIONAL_HISTORY.md
/docs/MASTER_CONTEXT.md

